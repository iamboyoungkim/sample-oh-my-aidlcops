{
  "$id": "https://awslabs.github.io/agent-plugins/schemas/skill-frontmatter.schema.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "additionalProperties": false,
  "description": "Schema for YAML frontmatter in SKILL.md files",
  "properties": {
    "agent": {
      "description": "Subagent type (when context: fork)",
      "type": "string"
    },
    "allowed-tools": {
      "description": "Comma-separated list of allowed tools",
      "type": "string"
    },
    "argument-hint": {
      "description": "Hint for expected arguments",
      "type": "string"
    },
    "context": {
      "description": "Run in forked subagent context",
      "enum": [
        "fork"
      ],
      "type": "string"
    },
    "description": {
      "description": "When to use this skill (for auto-triggering)",
      "minLength": 20,
      "type": "string"
    },
    "disable-model-invocation": {
      "default": false,
      "description": "Prevent Claude from auto-loading",
      "type": "boolean"
    },
    "license": {
      "description": "SPDX license identifier",
      "type": "string"
    },
    "metadata": {
      "description": "Plugin-specific metadata (author, version, etc.)",
      "type": "object"
    },
    "model": {
      "description": "Model to use when skill is active",
      "type": "string"
    },
    "name": {
      "description": "Skill name (kebab-case)",
      "maxLength": 64,
      "pattern": "^[a-z][a-z0-9-]*$",
      "type": "string"
    },
    "user-invocable": {
      "default": true,
      "description": "Show in slash command menu",
      "type": "boolean"
    },
    "ontology": {
      "description": "Declarative link between this skill and OMA ontology entities. Consumed by hooks and validators to ensure produced/consumed artifacts conform to their schemas.",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "produces": {
          "type": "array",
          "items": { "$ref": "ontology/../common/enums.schema.json#/$defs/entityRef" },
          "uniqueItems": true
        },
        "consumes": {
          "type": "array",
          "items": { "$ref": "ontology/../common/enums.schema.json#/$defs/entityRef" },
          "uniqueItems": true
        },
        "references": {
          "type": "array",
          "items": { "$ref": "ontology/../common/enums.schema.json#/$defs/entityRef" },
          "uniqueItems": true
        }
      }
    }
  },
  "required": [
    "name",
    "description"
  ],
  "definitions": {
    "entityRef": {
      "description": "Deprecated local alias — prefer $ref to common/enums.schema.json#/$defs/entityRef.",
      "$ref": "common/enums.schema.json#/$defs/entityRef"
    }
  },
  "title": "SKILL.md Frontmatter",
  "type": "object"
}
